#!/usr/bin/env python3
"""lspeak: TTS client that routes through lspeak-server.

Sends text to lspeak-server (OpenAI-compatible TTS HTTP endpoint) which
handles text normalization (KittenTTS + markdown stripping) and Wyoming
XTTS synthesis. Returns WAV audio for playback.

Usage:
    lspeak "Text to speak"
    echo "Text to speak" | lspeak
    lspeak -f file.txt
"""

import argparse
import json
import os
import subprocess
import sys
import urllib.request
import urllib.error


LSPEAK_SERVER = os.getenv("LSPEAK_SERVER", "http://10.2.0.125:8820")


def synthesize(text: str, voice: str = "jarvis") -> bytes | None:
    """Send text to lspeak-server, return WAV bytes."""
    url = f"{LSPEAK_SERVER}/v1/audio/speech"
    payload = json.dumps({
        "input": text,
        "voice": voice,
        "model": "xtts",
        "response_format": "wav",
    }).encode()

    req = urllib.request.Request(
        url,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            return resp.read()
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        print(f"lspeak: server error {e.code}: {body}", file=sys.stderr)
        return None
    except (urllib.error.URLError, OSError) as e:
        print(f"lspeak: connection failed: {e}", file=sys.stderr)
        return None


def play_wav(wav_bytes: bytes):
    """Play WAV audio via Windows native audio (bypasses WSLg resampling)."""
    # Write WAV to Windows-accessible temp path
    win_tmp = "/mnt/c/temp"
    os.makedirs(win_tmp, exist_ok=True)
    tmp_path = os.path.join(win_tmp, f"lspeak_{os.getpid()}.wav")
    win_path = tmp_path.replace("/mnt/c/", "C:\\").replace("/", "\\")

    try:
        with open(tmp_path, "wb") as f:
            f.write(wav_bytes)
        subprocess.run(
            ["powershell.exe", "-NoProfile", "-Command",
             f"(New-Object Media.SoundPlayer '{win_path}').PlaySync()"],
            stderr=subprocess.DEVNULL,
            timeout=120,
        )
    except FileNotFoundError:
        print("lspeak: powershell.exe not found, falling back to aplay", file=sys.stderr)
        proc = subprocess.Popen(["aplay", "-q", "-"], stdin=subprocess.PIPE, stderr=subprocess.DEVNULL)
        proc.communicate(input=wav_bytes)
    except subprocess.TimeoutExpired:
        print("lspeak: playback timed out", file=sys.stderr)
    finally:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass


def main():
    parser = argparse.ArgumentParser(description="lspeak: TTS via lspeak-server")
    parser.add_argument("text", nargs="*", help="Text to speak")
    parser.add_argument("--voice", "-v", default="jarvis", help="Voice name")
    parser.add_argument("-f", "--file", help="Read text from file")
    parser.add_argument("-o", "--output", help="Save WAV to file instead of playing")
    parser.add_argument("--list-voices", action="store_true", help="List available voices")
    parser.add_argument("--debug", action="store_true", help="Enable debug output")
    # Legacy args (accepted but ignored for backwards compatibility)
    parser.add_argument("--provider", default="lspeak-server", help=argparse.SUPPRESS)
    parser.add_argument("--no-cache", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--cache-threshold", type=float, help=argparse.SUPPRESS)
    parser.add_argument("--no-queue", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--queue-status", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--daemon-status", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--daemon-restart", action="store_true", help=argparse.SUPPRESS)
    parser.add_argument("--daemon-stop", action="store_true", help=argparse.SUPPRESS)

    args = parser.parse_args()

    if args.list_voices:
        try:
            with urllib.request.urlopen(f"{LSPEAK_SERVER}/v1/audio/speech/voices", timeout=5) as resp:
                data = json.loads(resp.read())
                for v in data.get("voices", []):
                    print(f"{v['name']} — {v.get('description', '')}")
        except Exception:
            print("jarvis — XTTS v2 fine-tuned Jarvis")
        return

    # Get text from arguments, file, or stdin
    if args.file:
        with open(args.file) as f:
            text = f.read().strip()
    elif args.text:
        text = " ".join(args.text)
    elif not sys.stdin.isatty():
        text = sys.stdin.read().strip()
    else:
        print("lspeak: no text provided", file=sys.stderr)
        sys.exit(1)

    if not text:
        return

    if args.debug:
        print(f"lspeak: speaking {len(text)} chars via {LSPEAK_SERVER}", file=sys.stderr)

    wav_bytes = synthesize(text, args.voice)
    if wav_bytes is None:
        print("lspeak: synthesis failed", file=sys.stderr)
        sys.exit(1)

    if args.output:
        with open(args.output, "wb") as f:
            f.write(wav_bytes)
        if args.debug:
            print(f"lspeak: saved to {args.output}", file=sys.stderr)
    else:
        play_wav(wav_bytes)


if __name__ == "__main__":
    main()
