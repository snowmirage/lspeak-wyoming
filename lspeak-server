    replace_numbers=True,
    replace_floats=True,
    expand_newlines=True,
    expand_tilde=True,
    expand_abbreviations=True,
    expand_symbols=True,
    expand_contractions=False,   # contractions sound natural in speech
    expand_model_names=True,
    expand_ordinals=True,
    expand_percentages=True,
    expand_currency=True,
    expand_time=True,
    expand_ranges=True,
    expand_units=True,
    expand_scale_suffixes=True,
    expand_scientific_notation=True,
    expand_fractions=True,
    expand_decades=True,
    expand_phone_numbers=True,
    expand_ip_addresses=True,
    normalize_leading_decimals=True,
    expand_roman_numerals=False,
    remove_urls=True,
    remove_emails=True,
    remove_html=True,
    remove_hashtags=False,
    remove_mentions=False,
    remove_punctuation=False,    # keep punctuation for XTTS prosody
    remove_stopwords=False,
    normalize_unicode=True,
    remove_accents=False,
    remove_extra_whitespace=True,
)


# ─────────────────────────────────────────────
# Markdown stripping (moved from Clarvis cleanForSpeech)
# ─────────────────────────────────────────────

def strip_markdown(text: str) -> str:
    """Strip markdown formatting to produce plain prose for TTS."""
    # Remove code blocks (``` ... ```)
    text = re.sub(r'```[\s\S]*?```', '', text)
    # Remove inline code — keep the text inside
    text = re.sub(r'`([^`]+)`', r'\1', text)
    # Remove markdown tables
    text = re.sub(r'^\|.*\|$', '', text, flags=re.MULTILINE)
    text = re.sub(r'^\s*[-|:]+\s*$', '', text, flags=re.MULTILINE)
    # Convert markdown links [text](url) to just text
    text = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', text)
    # Remove markdown headers
    text = re.sub(r'^#{1,6}\s+', '', text, flags=re.MULTILINE)
    # Remove bold/italic markers
    text = re.sub(r'\*{1,3}([^*]+)\*{1,3}', r'\1', text)
    text = re.sub(r'_{1,3}([^_]+)_{1,3}', r'\1', text)
    # Remove bullet points and numbered list markers
    text = re.sub(r'^\s*[-*+]\s+', '', text, flags=re.MULTILINE)
    text = re.sub(r'^\s*\d+\.\s+', '', text, flags=re.MULTILINE)
    # Remove file paths
    text = re.sub(r'(?:\.\/|\/[\w.-]+){2,}[\w.-]*', '', text)
    # Collapse whitespace
    text = re.sub(r'\n{3,}', '\n\n', text)
    text = re.sub(r' {2,}', ' ', text)
    # Join into single line
    text = ' '.join(line.strip() for line in text.split('\n') if line.strip())
    return text.strip()


