# Compound terms that need word-boundary-aware replacement
_COMPOUND_TERMS = [
    (re.compile(r'\blspeak-server\b', re.IGNORECASE), "L speak server"),
    (re.compile(r'\blspeak\b', re.IGNORECASE), "L speak"),
    (re.compile(r'\bWebUI\b'), "Web U I"),
    (re.compile(r'\bOpenClaw\b'), "Open Claw"),
    (re.compile(r'\bwyoming-xtts\b', re.IGNORECASE), "Wyoming X T T S"),
    (re.compile(r'\bdevenv\b', re.IGNORECASE), "dev env"),
    (re.compile(r'\bKittenTTS\b'), "Kitten T T S"),
    (re.compile(r'\bllama\.cpp\b'), "llama C P P"),
    (re.compile(r'\bllama-server\b'), "llama server"),
    (re.compile(r'\bESPHome\b'), "E S P Home"),
    (re.compile(r'\bClarvis\b'), "Clarvis"),
]

# Build regex for whole-word spell-out (longest match first to avoid partial)
_SPELL_OUT_RE = re.compile(
    r'\b(' + '|'.join(sorted(_SPELL_OUT.keys(), key=len, reverse=True)) + r')\b'
)


def expand_custom_abbreviations(text: str) -> str:
    """Expand project-specific abbreviations and compound terms."""
    # Compound terms first (more specific patterns)
    for pattern, replacement in _COMPOUND_TERMS:
        text = pattern.sub(replacement, text)
    # Whole-word spell-outs (case-sensitive)
    text = _SPELL_OUT_RE.sub(lambda m: _SPELL_OUT[m.group(1)], text)
    return text


def normalize_for_speech(text: str) -> str:
    """Full normalization pipeline: markdown strip → custom abbrevs → KittenTTS."""
    text = strip_markdown(text)
    text = expand_custom_abbreviations(text)
    text = _preprocessor(text)
    return text


# ─────────────────────────────────────────────
# Wyoming protocol
# ─────────────────────────────────────────────

class SpeechRequest(BaseModel):
    model: str = "xtts"
    input: str
    voice: str = "jarvis"
    response_format: str = "wav"
    speed: float = 1.0


def build_wav(pcm_data: bytes, rate: int, width: int, channels: int) -> bytes:
    data_size = len(pcm_data)
    header = struct.pack(
        "<4sI4s4sIHHIIHH4sI",
        b"RIFF", 36 + data_size, b"WAVE", b"fmt ", 16, 1,
        channels, rate, rate * channels * width, channels * width,
        width * 8, b"data", data_size,
    )
    return header + pcm_data


async def read_event(reader) -> tuple[dict, bytes] | None:
    line = await asyncio.wait_for(reader.readline(), timeout=120.0)
    if not line:
        return None
    header = json.loads(line)
    data = {}
    if header.get("data_length", 0) > 0:
        data = json.loads(await reader.readexactly(header["data_length"]))
    payload = b""
    if header.get("payload_length", 0) > 0:
        payload = await reader.readexactly(header["payload_length"])
    header["data"] = data
    return header, payload


async def synthesize(text: str, voice: str = "jarvis") -> bytes | None:
    try:
        reader, writer = await asyncio.wait_for(
            asyncio.open_connection(WYOMING_HOST, WYOMING_PORT),
            timeout=5.0,
        )
    except (OSError, asyncio.TimeoutError) as e:
        raise HTTPException(status_code=503, detail=f"Wyoming TTS unavailable: {e}")

    data_obj = {"text": text, "voice": {"name": voice}, "language": "en"}
    data_bytes = json.dumps(data_obj).encode()
    header = {
        "type": "synthesize",
        "version": "1.8.0",
        "data_length": len(data_bytes),
        "payload_length": 0,
    }
    writer.write(json.dumps(header).encode() + b"\n" + data_bytes)
    await writer.drain()

    rate, width, channels = 22050, 2, 1
    pcm_chunks: list[bytes] = []

    try:
        while True:
            result = await read_event(reader)
            if result is None:
                break
            evt_header, payload = result
            evt_type = evt_header.get("type", "")
            if evt_type == "audio-start":
                data = evt_header.get("data", {})
                rate = data.get("rate", rate)
                width = data.get("width", width)
                channels = data.get("channels", channels)
            elif evt_type == "audio-chunk":
                if payload:
                    pcm_chunks.append(payload)
            elif evt_type == "audio-stop":
                break
    except asyncio.TimeoutError:
        raise HTTPException(status_code=504, detail="Wyoming TTS timed out")
    finally:
        writer.close()

    if not pcm_chunks:
        raise HTTPException(status_code=500, detail="No audio returned from TTS")

    return build_wav(b"".join(pcm_chunks), rate, width, channels)


# ─────────────────────────────────────────────
# Audio format conversion
# ─────────────────────────────────────────────

_FORMAT_MAP = {
    "mp3": ("audio/mpeg", ["-f", "mp3", "-codec:a", "libmp3lame", "-q:a", "2"]),
    "opus": ("audio/opus", ["-f", "opus", "-codec:a", "libopus"]),
    "aac": ("audio/aac", ["-f", "adts", "-codec:a", "aac"]),
    "flac": ("audio/flac", ["-f", "flac", "-codec:a", "flac"]),
}


async def convert_audio(wav_bytes: bytes, fmt: str) -> tuple[bytes, str]:
    """Convert WAV bytes to another format using ffmpeg."""
    media_type, ffmpeg_args = _FORMAT_MAP[fmt]
    proc = await asyncio.create_subprocess_exec(
        "ffmpeg", "-i", "pipe:0", *ffmpeg_args, "-loglevel", "error", "pipe:1",
        stdin=asyncio.subprocess.PIPE,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    stdout, stderr = await proc.communicate(input=wav_bytes)
    if proc.returncode != 0:
        raise RuntimeError(f"ffmpeg exit {proc.returncode}: {stderr.decode(errors='replace')}")
    return stdout, media_type


# ─────────────────────────────────────────────
# API endpoints
# ─────────────────────────────────────────────

@app.post("/v1/audio/speech")
async def create_speech(request: SpeechRequest):
    if not request.input.strip():
        raise HTTPException(status_code=400, detail="Input text is empty")

    t0 = time.monotonic()

    # Normalize text for speech
    normalized = normalize_for_speech(request.input)
    t_norm = time.monotonic()

    if not normalized.strip():
        raise HTTPException(status_code=400, detail="Input text is empty after normalization")

    # Synthesize via Wyoming XTTS (always returns WAV/PCM)
    wav_bytes = await synthesize(normalized, request.voice)
    t_synth = time.monotonic()

    # Convert to requested format if needed
    output_bytes = wav_bytes
    media_type = "audio/wav"
    fmt = request.response_format.lower()
    if fmt in ("mp3", "opus", "aac", "flac"):
        try:
            output_bytes, media_type = await convert_audio(wav_bytes, fmt)
        except Exception as e:
            logger.warning("Audio conversion to %s failed (%s), returning WAV", fmt, e)

    norm_ms = (t_norm - t0) * 1000
    synth_ms = (t_synth - t_norm) * 1000
    total_ms = (time.monotonic() - t0) * 1000

    logger.info(
        "TTS: norm=%.0fms synth=%.0fms total=%.0fms chars=%d voice=%s fmt=%s",
        norm_ms, synth_ms, total_ms, len(normalized), request.voice, fmt,
    )

    return Response(
        content=output_bytes,
        media_type=media_type,
        headers={
            "X-TTS-Normalize-Ms": f"{norm_ms:.0f}",
            "X-TTS-Synthesize-Ms": f"{synth_ms:.0f}",
            "X-TTS-Total-Ms": f"{total_ms:.0f}",
        },
    )


